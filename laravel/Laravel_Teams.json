{
    "info": {
        "name": "Laravel Teams API",
        "description": "Документація RESTful API для взаємодії з даними команд Формули-1. Цей бекенд реалізовано за допомогою фреймворку Laravel. Містить приклади запитів для усіх стандартних CRUD-операцій.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Get All Teams",
            "request": {
                "method": "GET",
                "header": [],
                "description": "Запит для отримання списку усіх зареєстрованих команд. Відповідь формується у вигляді масиву JSON-об'єктів. Цей метод підходить для виведення загальної таблиці або списку на клієнтській стороні.",
                "url": {
                    "raw": "http://127.0.0.1:8000/api/teams",
                    "protocol": "http",
                    "host": ["127", "0", "0", "1"],
                    "port": "8000",
                    "path": ["api", "teams"]
                }
            }
        },
        {
            "name": "Get Single Team",
            "request": {
                "method": "GET",
                "header": [],
                "description": "Пошук та повернення даних однієї команди на основі її унікального ID, переданого у параметрах шляху (URL). Повертає 404 помилку у форматі JSON, якщо команда відсутня.",
                "url": {
                    "raw": "http://127.0.0.1:8000/api/teams/1",
                    "protocol": "http",
                    "host": ["127", "0", "0", "1"],
                    "port": "8000",
                    "path": ["api", "teams", "1"]
                }
            }
        },
        {
            "name": "Create Team",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "description": "Додавання нової команди до загального списку. Вимагає передачі JSON-об'єкта з ключовими атрибутами. Система автоматично згенерує новий ID на основі існуючих записів.",
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"name\": \"Aston Martin\",\n    \"principal\": \"Mike Krack\",\n    \"championships\": 0,\n    \"base\": \"Silverstone, UK\"\n}"
                },
                "url": {
                    "raw": "http://127.0.0.1:8000/api/teams",
                    "protocol": "http",
                    "host": ["127", "0", "0", "1"],
                    "port": "8000",
                    "path": ["api", "teams"]
                }
            }
        },
        {
            "name": "Update Team",
            "request": {
                "method": "PATCH",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "description": "Ендпоінт для модифікації атрибутів команди. Метод PATCH передбачає передачу лише тих параметрів, значення яких потрібно оновити. Приклад у тілі запиту показує оновлення кількості виграних чемпіонатів.",
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"championships\": 1\n}"
                },
                "url": {
                    "raw": "http://127.0.0.1:8000/api/teams/1",
                    "protocol": "http",
                    "host": ["127", "0", "0", "1"],
                    "port": "8000",
                    "path": ["api", "teams", "1"]
                }
            }
        },
        {
            "name": "Delete Team",
            "request": {
                "method": "DELETE",
                "header": [],
                "description": "Запит на видалення запису про команду. Потребує вказання ID в URL. Сервер знищує запис та повертає підтвердження у вигляді повідомлення разом із станом видаленого об'єкта.",
                "url": {
                    "raw": "http://127.0.0.1:8000/api/teams/1",
                    "protocol": "http",
                    "host": ["127", "0", "0", "1"],
                    "port": "8000",
                    "path": ["api", "teams", "1"]
                }
            }
        }
    ]
}
